# Dependencies
node_modules/

# Environment secrets - never commit this
.env

# Runtime session files
sessions/

# Generated / uploaded files
uploads/
receipts/

# Backups (large, should be managed separately)
backups/

# Live database files — never commit, managed per machine separately
data/*.json

# Temporary write files from atomic DB writes
data/*.tmp

# macOS system files
.DS_Store
.DS_Store?
._*
.Spotlight-V3
.Trashes

# Editor folders
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
