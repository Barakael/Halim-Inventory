{
  "name": "haslim-group-inventory-system",
  "version": "1.0.0",
  "description": "HASLIM GROUP LIMITED - Inventory Management System for Wholesale Food & Beverage Store",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:linux": "pkg server.js --targets node18-linux-x64 --output haslim-inventory",
    "build:all": "pkg server.js --targets node18-linux-x64,node18-win-x64 --output haslim-inventory"
  },
  "keywords": [
    "inventory",
    "wholesale",
    "retail",
    "pos",
    "stock-management"
  ],
